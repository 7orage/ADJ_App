{
  "expo": {
    "name": "Accueil du Jour",
    "slug": "ADJ2",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "notification": {
      "icon": "./assets/icon.png",
      "color": "#fb7500",
      "androidMode": "default",
      "androidCollapsedTitle": "Accueil du Jour"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.accueildujourapp.adj2",
      "infoPlist": {
        "UIBackgroundModes": [
          "remote-notification"
        ]
      }
    },
    "android": {
      "package": "com.accueildujourapp.adj2",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#fb7500",
          "sounds": []
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "2d835674-dcc9-4623-9399-7aef2bc74f17"
      }
    }
  }
}
